MIN_IOS_VERSION = '16.6'
platform :ios, MIN_IOS_VERSION  # Set your minimum deployment target

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper'))

flutter_ios_podfile_setup

target 'Runner' do
  # Rive's native renderer requires dynamic framework linkage on iOS.
  use_frameworks!

  # Firestore otherwise compiles its large C++/gRPC dependency graph during
  # every clean archive. Keep this tag aligned with firebase_core's native SDK
  # version so CocoaPods downloads a precompiled XCFramework during pod install.
  pod 'FirebaseFirestore',
      :git => 'https://github.com/invertase/firestore-ios-sdk-frameworks.git',
      :tag => '12.12.0'

  # If other Objective‑C pods complain about module maps, add:
  # use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # If you still need to patch BoringSSL flags, keep that post_install block.
end

post_install do |installer|
  installer.pods_project.targets.each do |t|
    flutter_additional_ios_build_settings(t)
    t.build_configurations.each do |config|
      # Keep pod targets aligned with the app's minimum iOS version.
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = MIN_IOS_VERSION
    end

    next unless t.name == 'rive_native'

    t.shell_script_build_phases.each do |phase|
      next unless phase.name&.include?('Rive Native Compile')

      phase.shell_script = phase.shell_script
        .gsub(
          '"$FLUTTER_ROOT/bin/dart" run rive_native:setup --verbose --platform ios',
          '(cd "${SRCROOT}/../.." && "$FLUTTER_ROOT/bin/dart" run rive_native:setup --verbose --platform ios)'
        )
        .gsub(
          'dart run rive_native:setup --verbose --platform ios',
          '(cd "${SRCROOT}/../.." && dart run rive_native:setup --verbose --platform ios)'
        )
    end
  end
end
